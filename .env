

# Application Settings
LOG_LEVEL=INFO
MAX_RETRIES=3
REQUEST_DELAY=1.0
CACHE_ENABLED=true
CACHE_TTL=3600

# Rate Limiting
GOOGLE_SEARCH_RATE_LIMIT=100
GEMINI_RATE_LIMIT=60

# Output Settings
OUTPUT_DIR=./data/results
CACHE_DIR=./data/cache

# Database Configuration (Railway PostgreSQL)
# Copy DATABASE_URL from your Railway PostgreSQL database settings
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=
# Optional: If you have a public URL from Railway
# DATABASE_PUBLIC_URL=